# Multi-Agent Docker Compose Environment
# Copy to .env and fill in values before running docker compose up.

# ── Platform URLs ─────────────────────────────────────────────────────────
THENVOI_REST_URL=https://app.thenvoi.com
THENVOI_WS_URL=wss://app.thenvoi.com/api/v1/socket/websocket

# ── API Keys ──────────────────────────────────────────────────────────────
# Claude Code planner (requires Anthropic API key or Claude MAX subscription)
ANTHROPIC_API_KEY=

# Codex agents (requires OpenAI API key)
OPENAI_API_KEY=

# ── Host Repo Path ────────────────────────────────────────────────────────
# Path to the repository on the host machine to mount into containers.
# Default: current directory (.)
REPO_PATH=.

# ── Codex Reviewer ────────────────────────────────────────────────────────
CODEX_REVIEWER_AGENT_KEY=reviewer
CODEX_REVIEWER_SANDBOX=external-sandbox
CODEX_REVIEWER_APPROVAL_MODE=manual
CODEX_REVIEWER_MODEL=gpt-5.3-codex
CODEX_REVIEWER_REASONING_EFFORT=xhigh

# ── Codex Implementer ────────────────────────────────────────────────────
CODEX_IMPLEMENTER_AGENT_KEY=implementer
CODEX_IMPLEMENTER_SANDBOX=external-sandbox
CODEX_IMPLEMENTER_APPROVAL_MODE=manual
CODEX_IMPLEMENTER_MODEL=gpt-5.3-codex
CODEX_IMPLEMENTER_REASONING_EFFORT=high

# ── Optional: Local Wheel Overrides ──────────────────────────────────────
# THENVOI_CLIENT_REST_WHEEL=
# PHOENIX_CHANNELS_CLIENT_WHEEL=
# THENVOI_CLIENT_REST_WHEEL_DIR=/tmp/thenvoi-client-rest
# PHOENIX_CHANNELS_CLIENT_WHEEL_DIR=/tmp/phoenix-client
