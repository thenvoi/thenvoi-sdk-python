# Required: Agent credentials from the Thenvoi platform
THENVOI_AGENT_ID=your-agent-uuid
THENVOI_API_KEY=your-api-key

# Optional: Platform URLs (defaults shown)
THENVOI_WS_URL=wss://app.band.ai/dashboard/api/v1/socket/websocket
THENVOI_REST_URL=https://app.band.ai/dashboard

# Required: Agent-to-handler mapping
# Format: agent_name:handler_name,agent_name2:handler_name2
AGENT_MAPPING=alice:alice_handler,bob:bob_handler

# Optional: Health check host/port (defaults shown)
# Use 127.0.0.1 outside of containers to bind to localhost only.
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080

# Optional: Session TTL in seconds (default: 86400 = 24 hours)
# Sessions inactive longer than this are evicted automatically.
# Set to 0 to disable eviction entirely.
SESSION_TTL=86400

# Optional: Handler execution timeout in seconds (default: 300 = 5 minutes)
# Handlers that exceed this timeout are cancelled and reported as failed.
# Set to 0 to disable timeout entirely.
HANDLER_TIMEOUT=300

# Optional: Logging level (default: INFO)
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- LangChain handler ---

# Required when using LangChainHandler:
# Single URL for all agents, or per-agent mapping.
# Single URL:    LANGCHAIN_URLS=http://host.docker.internal:8000
#   (auto-appends /invoke when using base_url mode)
# Per-agent:     LANGCHAIN_URLS=alice:http://localhost:8000/invoke,bob:http://localhost:8001/invoke
#   (URLs used as-is — include the full path)
LANGCHAIN_URLS=http://host.docker.internal:8000

# Optional: LangChain invocation timeout in seconds (default: 120)
LANGCHAIN_TIMEOUT=120

# --- AWS / AgentCore handler ---

# Required when using AgentCoreHandler:
# Full ARN of the Bedrock AgentCore agent runtime
AGENTCORE_RUNTIME_ARN=arn:aws:bedrock:us-east-1:123456789012:agent/your-agent-id

# AWS region for AgentCore API calls
AWS_DEFAULT_REGION=us-east-1

# Optional: AgentCore invocation timeout in seconds (default: 120)
AGENTCORE_TIMEOUT=120
