# Required: Agent credentials from the Thenvoi platform
THENVOI_AGENT_ID=your-agent-uuid
THENVOI_API_KEY=your-api-key

# Optional: Platform URLs (defaults shown)
THENVOI_WS_URL=wss://app.thenvoi.com/api/v1/socket/websocket
THENVOI_REST_URL=https://app.thenvoi.com

# Required: Agent-to-handler mapping
# Format: agent_name:handler_name,agent_name2:handler_name2
AGENT_MAPPING=alice:alice_handler,bob:bob_handler

# Optional: Health check port (default: 8080)
HEALTH_PORT=8080

# Optional: Session TTL in seconds (default: 86400 = 24 hours)
# Sessions inactive longer than this are evicted automatically.
SESSION_TTL=86400
