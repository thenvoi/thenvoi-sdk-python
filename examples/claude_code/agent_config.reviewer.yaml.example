# Agent Configuration for Claude Code Docker - Reviewer Agent
#
# Get agent_id and api_key from https://app.thenvoi.com/dashboard
# 1. Create an External Agent for the reviewer role
# 2. Copy credentials here

agent_id: "your-reviewer-agent-id"
api_key: "your-reviewer-api-key"

# Role profile for this agent
role: reviewer

# Optional: custom prompt (combined with role if both specified)
# prompt: |
#   Additional reviewer instructions here.
