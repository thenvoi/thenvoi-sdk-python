# Thenvoi Platform URLs
THENVOI_REST_URL=https://app.thenvoi.com
THENVOI_WS_URL=wss://app.thenvoi.com/api/v1/socket/websocket

# Repository path to mount (default: ../../ - SDK repo root)
# Override to mount a different repository:
#   REPO_PATH=/path/to/your/project
REPO_PATH=../../

# Optional: GitHub token for git operations within container
# Required if you need to clone/push to private repositories
# GITHUB_TOKEN=ghp_xxxxx
