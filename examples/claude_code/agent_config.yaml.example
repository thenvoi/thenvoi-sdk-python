# Agent Configuration for Claude Code Docker
#
# Get agent_id and api_key from https://app.thenvoi.com/dashboard
# 1. Create an External Agent
# 2. Copy credentials here

agent_id: "your-agent-id"
api_key: "your-api-key"

# Optional: use a predefined role profile
# Available roles: planner, reviewer, implementer
# Can also be set via AGENT_ROLE environment variable
role: planner

# Optional: custom prompt (combined with role if both specified)
# prompt: |
#   Additional instructions here.
