# Planner/Reviewer pair defaults for examples/codex/docker-compose.plan-review.yml

# Agent keys in agent_config.yaml
CODEX_PLANNER_AGENT_KEY=codex_planner
CODEX_REVIEWER_AGENT_KEY=codex_reviewer

# Provider transport and sandbox
CODEX_TRANSPORT=stdio
CODEX_PLANNER_SANDBOX=external-sandbox
CODEX_REVIEWER_SANDBOX=external-sandbox

# Shared workspace in container
CODEX_PLANNER_CWD=/workspace/repo
CODEX_REVIEWER_CWD=/workspace/repo

# Approval handling
CODEX_PLANNER_APPROVAL_MODE=manual
CODEX_REVIEWER_APPROVAL_MODE=manual

# Optional Thenvoi host endpoints override for Docker Desktop
# THENVOI_REST_URL_DOCKER=http://host.docker.internal:4000
# THENVOI_WS_URL_DOCKER=ws://host.docker.internal:4000/api/v1/socket/websocket

# Optional prompt overrides (single-line strings)
# CODEX_PLANNER_CUSTOM_SECTION=You are the planning agent...
# CODEX_REVIEWER_CUSTOM_SECTION=You are the review agent...
