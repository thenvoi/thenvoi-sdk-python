# Claude Code Desktop Agent Configuration
#
# NO Anthropic API Key required! This uses your local Claude Code CLI installation.

# Thenvoi Platform Credentials (required)
THENVOI_AGENT_ID=your-agent-uuid-here
THENVOI_API_KEY=your-api-key-here

# Optional: Claude Code CLI path (if not in PATH)
# CLAUDE_CODE_PATH=/usr/local/bin/claude

# Thenvoi Platform URLs
THENVOI_REST_URL=https://app.thenvoi.com/
THENVOI_WS_URL=wss://app.thenvoi.com/api/v1/socket/websocket
